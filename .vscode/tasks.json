{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compilar Kotlin Native",
            "type": "shell",
            "command": "kotlinc-native",
            "args": [
                "${file}",
                "-o",
                "${fileBasenameNoExtension}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
